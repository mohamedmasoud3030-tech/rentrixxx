{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".tmp-tests",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "types": ["node"],
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "jsx": "react-jsx"
  },
  "include": [
    "tests/**/*.ts",
    "src/constants/status.ts",
    "src/utils/status.ts",
    "src/utils/validation.ts",
    "src/utils/helpers.ts"
  ]
}
