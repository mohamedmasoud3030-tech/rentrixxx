{
  "name": "rentrix-web",
  "version": "1.0.0",
  "description": "نظام ادارة مؤسسات شامل لإدارة العقارات",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "npm run build",
    "typecheck": "npx tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "node -e \"const fs=require('fs');const cp=require('child_process');const script='scripts/lint-check.mjs';if(fs.existsSync(script)){const r=cp.spawnSync(process.execPath,[script],{stdio:'inherit'});process.exit(r.status??1);}console.log('⚠️ scripts/lint-check.mjs not found; skipping custom lint checks.');\"",
    "test:prepare": "node scripts/prepare-tests.mjs",
    "test": "npm run test:unit && npm run test:service && npm run test:critical",
    "test:unit": "npm run test:prepare && node --test .tmp-tests/tests/unit/status.test.js .tmp-tests/tests/unit/finance-rounding.test.js",
    "test:service": "npm run test:prepare && node --test .tmp-tests/tests/service/validation.test.js .tmp-tests/tests/service/security-validation.test.js .tmp-tests/tests/service/aged-receivables.test.js",
    "test:critical": "npm run test:prepare && node --test .tmp-tests/tests/critical/critical-flows.test.js",
    "ci": "npm run preflight && npm run typecheck && npm run lint && npm run test && npm run build",
    "preflight": "node scripts/preflight.mjs",
    "readiness": "node scripts/deployment-readiness.mjs",
    "readiness:strict": "node scripts/deployment-readiness.mjs --strict",
    "schema:drift:check": "node scripts/schema-drift-check.mjs",
    "start": "vite preview --host 0.0.0.0 --port 4173"
  },
  "author": "Mohamed Masoud",
  "license": "UNLICENSED",
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@supabase/supabase-js": "^2.100.0",
    "date-fns": "^4.1.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4",
    "typescript": "^5.8.3"
  }
}
