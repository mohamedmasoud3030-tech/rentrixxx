{
  "name": "rentrix-web",
  "version": "1.0.0",
  "description": "نظام ادارة مؤسسات شامل لإدارة العقارات",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "npm run build",
    "typecheck": "node scripts/typecheck.mjs",
    "lint": "node scripts/lint-check.mjs",
    "test": "npm run test:unit && npm run test:service && npm run test:critical && npm run test:stress",
    "test:unit": "node --experimental-transform-types --experimental-specifier-resolution=node --test tests/unit/status.test.ts",
    "test:service": "node --experimental-transform-types --experimental-specifier-resolution=node --test tests/service/validation.test.ts tests/service/security-validation.test.ts",
    "test:critical": "node --experimental-transform-types --experimental-specifier-resolution=node --test tests/critical/critical-flows.test.ts",
    "test:stress": "node --experimental-transform-types --experimental-specifier-resolution=node --test tests/critical/stress-scenarios.test.ts",
    "readiness": "node scripts/deployment-readiness.mjs",
    "readiness:strict": "node scripts/deployment-readiness.mjs --strict",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run readiness && npm run build"
  },
  "author": "Mohamed Masoud",
  "license": "UNLICENSED",
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@supabase/supabase-js": "^2.100.0",
    "date-fns": "^4.1.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4"
  }
}
