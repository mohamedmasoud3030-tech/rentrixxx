{
  "name": "rentrix-desktop",
  "version": "1.0.0",
  "description": "نظام ادارة مؤسسات شامل لإدارة العقارات",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "author": "يعقوب فضل الخصيبي",
  "license": "UNLICENSED",
  "dependencies": {
    "@google/genai": "^1.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "lucide-react": "^0.563.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "react-hot-toast": "^2.6.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "vite": "^5.3.4",
    "@vitejs/plugin-react": "^4.3.1",
    "tailwindcss": "^3.4.6",
    "postcss": "^8.4.39",
    "autoprefixer": "^10.4.19"
  },
  "build": {
    "appId": "com.rentrix.app",
    "productName": "Rentrix",
    "files": [
      "dist/",
      "electron/"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}