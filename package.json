{
  "name": "rentrix-production-workspace",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "pnpm": "10.11.1"
  },
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "install:clean": "pnpm install --frozen-lockfile",
    "build": "pnpm -r --if-present run build",
    "typecheck": "tsc -b && pnpm -r --filter ./artifacts/rentrix --if-present run typecheck",
    "lint": "pnpm -r --filter ./artifacts/rentrix --if-present run lint"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
