{
  "version": "1.0.0",
  "plugin": "understand-anything",
  "description": "Local knowledge graph seed for the Understand Anything plugin.",
  "nodes": [
    {
      "id": "understand-anything",
      "type": "plugin",
      "label": "Understand Anything"
    },
    {
      "id": "entrypoint",
      "type": "command",
      "label": "/understand"
    },
    {
      "id": "workspace-root",
      "type": "workspace",
      "label": "/workspace/rentrixxx"
    },
    {
      "id": "app-module",
      "type": "package",
      "label": "artifacts/rentrix"
    },
    {
      "id": "validation",
      "type": "workflow",
      "label": "typecheck + build + lint"
    }
  ],
  "edges": [
    {
      "from": "understand-anything",
      "to": "entrypoint",
      "type": "exposes"
    },
    {
      "from": "entrypoint",
      "to": "workspace-root",
      "type": "analyzes"
    },
    {
      "from": "workspace-root",
      "to": "app-module",
      "type": "contains"
    },
    {
      "from": "app-module",
      "to": "validation",
      "type": "verified_by"
    }
  ]
}
